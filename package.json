{
	"name": "chneau.github.io",
	"type": "module",
	"scripts": {
		"start": "rsbuild dev",
		"build": "bun run _genIcs.ts && rsbuild build && cp README.md dist/",
		"deploy": "bun run build && gh-pages --dist dist --branch master; rm -rf dist",
		"upgrade": "bun update --latest",
		"check": "bun run --sequential check:deno check:oxlint check:biome lint",
		"lint": "tsc --noEmit",
		"all": "bun run --sequential upgrade check:deno check:oxlint check:biome lint",
		"check:deno": "deno fmt --use-tabs --quiet",
		"check:oxlint": "oxlint --fix-dangerously --quiet",
		"check:biome": "timeout 3s biome check --write --unsafe ."
	},
	"dependencies": {
		"@ant-design/charts": "^2.6.7",
		"@tanstack/react-query": "^5.90.21",
		"antd": "^6.3.1",
		"canvas-confetti": "^1.9.4",
		"dayjs": "^1.11.19",
		"es-toolkit": "^1.44.0",
		"fuse.js": "^7.1.0",
		"html2canvas": "^1.4.1",
		"i18next": "^25.8.13",
		"i18next-browser-languagedetector": "^8.2.1",
		"posthog-js": "^1.356.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-i18next": "^16.5.4",
		"valtio": "^2.3.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@rsbuild/core": "^1.7.3",
		"@rsbuild/plugin-react": "^1.4.5",
		"@types/bun": "^1.3.9",
		"@types/canvas-confetti": "^1.9.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"gh-pages": "^6.3.0",
		"typescript": "^5.9.3"
	}
}
